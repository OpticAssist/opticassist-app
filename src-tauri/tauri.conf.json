{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Optic Assist",
  "version": "0.1.0",
  "identifier": "com.opticassist.desktop",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Optic Assist",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "macOS": {
      "entitlements": "entitlements.plist",
      "infoPlist": "Info.plist"
    },
    "active": true,
    "targets": "all",
    "icon": [
      "icons/oa-logo-300x300.png"
    ]
  }
}
